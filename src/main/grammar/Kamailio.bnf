{
  parserClass="io.github.braams.kamailio.parser.KamailioParser"
  parserUtilClass="io.github.braams.kamailio.parser.KamailioParserUtil"

  extends="io.github.braams.kamailio.psi.impl.KamailioPsiElementBase"

  psiClassPrefix="Kamailio"
  psiImplClassSuffix="Impl"
  psiPackage="io.github.braams.kamailio.psi"
  psiImplPackage="io.github.braams.kamailio.psi.impl"

  elementTypeHolderClass="io.github.braams.kamailio.psi.KamailioTypes"
  elementTypeClass="io.github.braams.kamailio.psi.KamailioElementType"
  tokenTypeClass="io.github.braams.kamailio.psi.KamailioTokenType"

  tokens=[
    LINE_COMMENT='regexp:#[^!][^\r\n]*'
    BLOCK_COMMENT='regexp:/\*.*\*/'

    PP_SHEBANG_KW='#!KAMAILIO'
    PP_DEFINE_KW='#!define'
    PP_UNDEF_KW='#!undef'
    PP_IFDEF_KW='#!ifdef'
    PP_IFNDEF_KW='#!ifndef'
    PP_IFEXP_KW='#!ifexp'
    PP_ELSE_KW='#!else'
    PP_ENDIF_KW='#!endif'
    PP_SUBST_KW='#!substdef'
    PP_DEFENV_KW='#!defenv'
    PP_UNKNOWN_KW='#!unknown'
    PP_TEXT='pp_text'

    REQUEST_ROUTE_KW='request_route'
    REPLY_ROUTE_KW='reply_route'
    ONREPLY_ROUTE_KW='onreply_route'
    FAILURE_ROUTE_KW='failure_route'
    BRANCH_ROUTE_KW='branch_route'
    ONSEND_ROUTE_KW='onsend_route'
    EVENT_ROUTE_KW='event_route'
    ROUTE_KW='route'
    IF_KW='if'
    ELSE_KW='else'
    SWITCH_KW='switch'
    CASE_KW='case'
    DEFAULT_KW='default'
    WHILE_KW='while'
    BREAK_KW='break'
    RETURN_KW='return'
    EXIT_KW='exit'
    DROP_KW='drop'
    LOADMODULE_KW='loadmodule'
    LOADPATH_KW='loadpath'
    MODPARAM_KW='modparam'
    INCLUDE_FILE_KW='include_file'
    IMPORT_FILE_KW='import_file'
    DESC_KW='desc'

    IDENT='regexp:[a-zA-Z_][a-zA-Z0-9_]*'
    EVENT_NAME='regexp:[a-zA-Z][0-9a-zA-Z_-]*(:[a-zA-Z][0-9a-zA-Z_-]*)*'
    NUMBER='regexp:[0-9]+'
    IP_LITERAL='regexp:[0-9]{1,3}(\.[0-9]{1,3}){3}'
    DQUOTE='"'
    STRING_TEXT='regexp:[^"$]+'
    STRING_INTERP='regexp:\$[a-zA-Z_][a-zA-Z0-9_]*'
    SQ_STRING="regexp:'[^']*'"

    EQEQ='=='
    NEQ='!='
    MATCH_OP='=~'
    NMATCH_OP='!~'
    LE='<='
    GE='>='
    LT='<'
    GT='>'
    ANDAND='&&'
    OROR='||'
    FATARROW='=>'
    EQ='='
    NOT='!'
    PLUS='+'
    MINUS='-'
    STAR='*'
    SLASH='/'
    AMP='&'
    PIPE='|'
    DOLLAR='$'
    LPAREN='('
    RPAREN=')'
    LBRACE='{'
    RBRACE='}'
    LBRACK='['
    RBRACK=']'
    SEMICOLON=';'
    COMMA=','
    COLON=':'
    DOT='.'
  ]
}

kamailioFile ::= item_*

private item_ ::= pp_directive
  | include_directive
  | loadmodule_stmt
  | loadpath_stmt
  | modparam_stmt
  | route_def
  | global_assignment
  {recoverWhile=item_recover}

// IDENT alone is NOT a stop token (garbage like SQL inside inactive ifdefs starts with plain
// identifiers and recovery must be able to eat it) — only "IDENT =" / "IDENT ." which really
// starts a global assignment.
private item_recover ::= !(PP_SHEBANG_KW | PP_DEFINE_KW | PP_UNDEF_KW | PP_IFDEF_KW | PP_IFNDEF_KW | PP_IFEXP_KW
  | PP_ELSE_KW | PP_ENDIF_KW | PP_SUBST_KW | PP_DEFENV_KW | PP_UNKNOWN_KW
  | INCLUDE_FILE_KW | IMPORT_FILE_KW | LOADMODULE_KW | LOADPATH_KW | MODPARAM_KW
  | ROUTE_KW | REQUEST_ROUTE_KW | REPLY_ROUTE_KW | ONREPLY_ROUTE_KW | FAILURE_ROUTE_KW
  | BRANCH_ROUTE_KW | ONSEND_ROUTE_KW | EVENT_ROUTE_KW | IDENT (EQ | DOT))

// ---------------- Preprocessor ----------------

pp_directive ::= pp_shebang | pp_define | pp_undef | pp_ifdef | pp_ifndef | pp_ifexp
  | pp_else | pp_endif | pp_subst | pp_env | pp_unknown

pp_shebang ::= PP_SHEBANG_KW PP_TEXT? {pin=1}

pp_define ::= PP_DEFINE_KW <<sameLine>> IDENT pp_value? {
  pin=1
  mixin="io.github.braams.kamailio.psi.impl.KamailioPpDefineMixin"
  implements="io.github.braams.kamailio.psi.KamailioNamedElement"
}

pp_undef ::= PP_UNDEF_KW (<<sameLine>> IDENT)? {pin=1}
pp_ifdef ::= PP_IFDEF_KW (<<sameLine>> IDENT)? {pin=1}
pp_ifndef ::= PP_IFNDEF_KW (<<sameLine>> IDENT)? {pin=1}
pp_ifexp ::= PP_IFEXP_KW PP_TEXT? {pin=1}
pp_else ::= PP_ELSE_KW PP_TEXT? {pin=1}
pp_endif ::= PP_ENDIF_KW PP_TEXT? {pin=1}
pp_subst ::= PP_SUBST_KW PP_TEXT? {
  pin=1
  mixin="io.github.braams.kamailio.psi.impl.KamailioPpSubstMixin"
}
pp_env ::= PP_DEFENV_KW PP_TEXT? {pin=1}
pp_unknown ::= PP_UNKNOWN_KW PP_TEXT? {pin=1}

pp_value ::= pp_value_item_+
private pp_value_item_ ::= <<sameLine>> pp_value_token_
private pp_value_token_ ::= string_literal | SQ_STRING | pv | NUMBER | IP_LITERAL | IDENT | DESC_KW
  | COLON | DOT | SLASH | COMMA | PLUS | MINUS | STAR | NOT | AMP | PIPE
  | EQEQ | NEQ | MATCH_OP | NMATCH_OP | LT | GT | LE | GE | ANDAND | OROR | EQ | FATARROW
  | LPAREN | RPAREN | LBRACK | RBRACK | SEMICOLON

// ---------------- Top-level statements ----------------

include_directive ::= (INCLUDE_FILE_KW | IMPORT_FILE_KW) string_literal {
  pin=1
  mixin="io.github.braams.kamailio.psi.impl.KamailioIncludeDirectiveMixin"
}

loadmodule_stmt ::= LOADMODULE_KW string_value {
  pin=1
  mixin="io.github.braams.kamailio.psi.impl.KamailioLoadmoduleMixin"
}

loadpath_stmt ::= LOADPATH_KW string_value {pin=1}

modparam_stmt ::= MODPARAM_KW LPAREN string_value COMMA string_value COMMA modparam_value RPAREN {
  pin=1
  mixin="io.github.braams.kamailio.psi.impl.KamailioModparamMixin"
}

modparam_value ::= string_value | MINUS? NUMBER | pv | identifier

global_assignment ::= param_name EQ global_value? desc_clause? {
  pin=2
  mixin="io.github.braams.kamailio.psi.impl.KamailioGlobalAssignmentMixin"
}

param_name ::= IDENT (DOT IDENT)*
desc_clause ::= DESC_KW string_literal {pin=1}

global_value ::= global_atom_+
private global_atom_ ::= !(param_name EQ) atom_g_
private atom_g_ ::= string_literal | SQ_STRING | NUMBER | IP_LITERAL | pv | IDENT
  | COLON | DOT | SLASH | MINUS | STAR | LBRACK | RBRACK

// ---------------- Routes ----------------

route_def ::= route_kind route_name_decl? block {
  pin=1
  mixin="io.github.braams.kamailio.psi.impl.KamailioRouteDefMixin"
  implements="io.github.braams.kamailio.psi.KamailioNamedElement"
}

route_kind ::= ROUTE_KW | REQUEST_ROUTE_KW | REPLY_ROUTE_KW | ONREPLY_ROUTE_KW
  | FAILURE_ROUTE_KW | BRANCH_ROUTE_KW | ONSEND_ROUTE_KW | EVENT_ROUTE_KW

route_name_decl ::= LBRACK route_name RBRACK {pin=1}
route_name ::= IDENT | EVENT_NAME | NUMBER

block ::= LBRACE statement* RBRACE {pin=1}

statement ::= block | if_stmt | switch_stmt | while_stmt | pp_directive | include_directive
  | flow_stmt | assign_stmt | expr_stmt | empty_stmt
  {recoverWhile=statement_recover}

private statement_recover ::= !(RBRACE | LBRACE | SEMICOLON | IF_KW | ELSE_KW | SWITCH_KW | CASE_KW
  | DEFAULT_KW | WHILE_KW | BREAK_KW | RETURN_KW | EXIT_KW | DROP_KW
  | ROUTE_KW | REQUEST_ROUTE_KW | REPLY_ROUTE_KW | ONREPLY_ROUTE_KW | FAILURE_ROUTE_KW
  | BRANCH_ROUTE_KW | ONSEND_ROUTE_KW | EVENT_ROUTE_KW
  | PP_SHEBANG_KW | PP_DEFINE_KW | PP_UNDEF_KW | PP_IFDEF_KW | PP_IFNDEF_KW | PP_IFEXP_KW | PP_ELSE_KW | PP_ENDIF_KW
  | PP_SUBST_KW | PP_DEFENV_KW | PP_UNKNOWN_KW
  | INCLUDE_FILE_KW | IMPORT_FILE_KW | LOADMODULE_KW | LOADPATH_KW | MODPARAM_KW
  | DOLLAR | NOT | IDENT)

if_stmt ::= IF_KW condition statement else_clause? {pin=1}
condition ::= LPAREN expr RPAREN {pin=1}
else_clause ::= ELSE_KW statement {pin=1}

switch_stmt ::= SWITCH_KW condition LBRACE switch_case* RBRACE {pin=1}
switch_case ::= case_clause | default_clause | pp_directive
case_clause ::= CASE_KW case_value COLON statement* {pin=1}
default_clause ::= DEFAULT_KW COLON statement* {pin=1}
case_value ::= MINUS? NUMBER | string_literal | identifier

while_stmt ::= WHILE_KW condition statement {pin=1}

flow_stmt ::= (RETURN_KW expr? | BREAK_KW | EXIT_KW | DROP_KW) SEMICOLON {pin=1}
assign_stmt ::= pv EQ expr SEMICOLON {pin=2}
expr_stmt ::= expr SEMICOLON {pin=1}
empty_stmt ::= SEMICOLON

// ---------------- Expressions ----------------

expr ::= or_expr
or_expr ::= and_expr (OROR and_expr)*
and_expr ::= cmp_expr (ANDAND cmp_expr)*
cmp_expr ::= add_expr (cmp_op_ add_expr)?
private cmp_op_ ::= EQEQ | NEQ | MATCH_OP | NMATCH_OP | LE | GE | LT | GT
add_expr ::= mul_expr ((PLUS | MINUS | AMP | PIPE) mul_expr)*
mul_expr ::= unary_expr ((STAR | SLASH) unary_expr)*
unary_expr ::= (NOT | MINUS) unary_expr | primary_expr

private primary_expr ::= paren_expr | route_call | call_expr | pv | literal | identifier_ref

paren_expr ::= LPAREN expr RPAREN {pin=1}

route_call ::= ROUTE_KW LPAREN route_ref RPAREN {pin=1}
route_ref ::= IDENT | NUMBER | pv

call_expr ::= identifier LPAREN arg_list? RPAREN {
  pin=2
  mixin="io.github.braams.kamailio.psi.impl.KamailioCallExprMixin"
}
arg_list ::= expr (COMMA expr)*

literal ::= string_literal | SQ_STRING | NUMBER | IP_LITERAL
identifier_ref ::= identifier
identifier ::= IDENT | DESC_KW

string_literal ::= DQUOTE string_part_* DQUOTE {pin=1}
private string_part_ ::= STRING_TEXT | STRING_INTERP
string_value ::= (string_literal | SQ_STRING)+

// ---------------- Pseudo-variables ----------------

pv ::= DOLLAR (pv_paren | pv_plain) {
  pin=1
  mixin="io.github.braams.kamailio.psi.impl.KamailioPvMixin"
}

pv_plain ::= identifier pv_arg?
pv_arg ::= LPAREN pv_key RPAREN {pin=1}
pv_paren ::= LPAREN pv_inner RPAREN {pin=1}
pv_inner ::= pv_plain pv_index? transformation*
pv_index ::= LBRACK (MINUS? NUMBER | pv | STAR) RBRACK {pin=1}

transformation ::= LBRACE trans_name trans_args_? RBRACE {
  pin=1
  mixin="io.github.braams.kamailio.psi.impl.KamailioTransformationMixin"
}
trans_name ::= identifier (DOT identifier)*
private trans_args_ ::= (COMMA trans_arg)+
trans_arg ::= trans_arg_item_+
private trans_arg_item_ ::= identifier | NUMBER | MINUS | pv | string_literal | SQ_STRING
  | DOT | STAR | SLASH | COLON | PLUS

pv_key ::= pv_key_item_+
private pv_key_item_ ::= identifier | NUMBER | IP_LITERAL | pv | string_literal | SQ_STRING
  | DOT | MINUS | STAR | SLASH | COLON | FATARROW | EQ | PLUS | COMMA | LBRACK | RBRACK
